<Page x:Class="DnDInitiativeTracker.Pages.CampaignsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:DnDInitiativeTracker.ViewModels"
      Title="Campaigns"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32" MaxWidth="600" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Campaigns"
                       Style="{StaticResource PageHeaderStyle}"/>
            <TextBlock Text="Select or create a campaign to get started."
                       Style="{StaticResource PageSubheaderStyle}"/>

            <!-- New campaign button -->
            <ui:Button Content="New Campaign"
                       Icon="{ui:SymbolIcon Add24}"
                       Command="{Binding BeginCreateCampaignCommand}"
                       Appearance="Primary"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Margin="0,0,0,20"/>

            <!-- New campaign form -->
            <Border Style="{StaticResource DashboardCardStyle}"
                    Margin="0,0,0,20"
                    Visibility="{Binding IsCreatingCampaign, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="NEW CAMPAIGN" Style="{StaticResource SectionHeaderStyle}"/>

                    <TextBlock Text="CAMPAIGN NAME" Style="{StaticResource FieldLabelStyle}"/>
                    <ui:TextBox Text="{Binding NewCampaignName, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="e.g. The Lost Mine"
                                Margin="0,0,0,12"/>

                    <TextBlock Text="DESCRIPTION (OPTIONAL)" Style="{StaticResource FieldLabelStyle}"/>
                    <ui:TextBox Text="{Binding NewCampaignDescription, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="A short description…"
                                Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               FontSize="11" Margin="0,0,0,8"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullOrEmptyToVisibility}}"/>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Create"
                                   Appearance="Primary"
                                   Style="{StaticResource PrimaryButtonStyle}"
                                   Command="{Binding ConfirmCreateCampaignCommand}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Cancel"
                                   Style="{StaticResource SecondaryButtonStyle}"
                                   Command="{Binding CancelCreateCampaignCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Campaign list -->
            <ItemsControl ItemsSource="{Binding Campaigns}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,10"
                                Cursor="Hand"
                                MouseLeftButtonUp="CampaignCard_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                                        Margin="0,0,14,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#4A90D9" Offset="0"/>
                                            <GradientStop Color="#357ABD" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="BookStar24" FontSize="18"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"/>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12" TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0"/>
                                </StackPanel>

                                <ui:Button Grid.Column="2"
                                           Icon="{ui:SymbolIcon Delete24}"
                                           Appearance="Danger"
                                           ToolTip="Delete campaign"
                                           VerticalAlignment="Center"
                                           CornerRadius="8"
                                           Command="{Binding DataContext.DeleteCampaignCommand,
                                                     RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>

