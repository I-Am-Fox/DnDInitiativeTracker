<Page x:Class="DnDInitiativeTracker.Pages.EncountersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Encounters"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32" MaxWidth="600" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Encounters"
                       Style="{StaticResource PageHeaderStyle}"/>
            <TextBlock Text="{Binding SelectedCampaignName}"
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Select a campaign first to manage encounters."
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="0,0,0,24"
                       Visibility="{Binding HasNoCampaign, Converter={StaticResource BoolToVisibility}}"/>

            <!-- New encounter button -->
            <ui:Button Content="New Encounter"
                       Icon="{ui:SymbolIcon Add24}"
                       Command="{Binding BeginCreateEncounterCommand}"
                       Appearance="Primary"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Margin="0,0,0,20"
                       IsEnabled="{Binding HasCampaign}"/>

            <!-- New encounter form -->
            <Border Style="{StaticResource DashboardCardStyle}"
                    Margin="0,0,0,20"
                    Visibility="{Binding IsCreatingEncounter, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="NEW ENCOUNTER" Style="{StaticResource SectionHeaderStyle}"/>

                    <TextBlock Text="ENCOUNTER NAME" Style="{StaticResource FieldLabelStyle}"/>
                    <ui:TextBox Text="{Binding NewEncounterName, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="e.g. Goblin Ambush"
                                Margin="0,0,0,12"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               FontSize="11" Margin="0,0,0,8"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullOrEmptyToVisibility}}"/>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Create"
                                   Appearance="Primary"
                                   Style="{StaticResource PrimaryButtonStyle}"
                                   Command="{Binding ConfirmCreateEncounterCommand}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Cancel"
                                   Style="{StaticResource SecondaryButtonStyle}"
                                   Command="{Binding CancelCreateEncounterCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Encounter list -->
            <ItemsControl ItemsSource="{Binding Encounters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,10"
                                Cursor="Hand"
                                MouseLeftButtonUp="EncounterCard_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                                        Margin="0,0,14,0" VerticalAlignment="Center"
                                        Background="#2A3A5C">
                                    <ui:SymbolIcon Symbol="Flash24" FontSize="18"
                                                   Foreground="#4A90D9"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"
                                           VerticalAlignment="Center"/>

                                <ui:Button Grid.Column="2"
                                           Icon="{ui:SymbolIcon Delete24}"
                                           Appearance="Danger"
                                           ToolTip="Delete encounter"
                                           VerticalAlignment="Center"
                                           CornerRadius="8"
                                           Command="{Binding DataContext.DeleteEncounterCommand,
                                                     RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>

