<Page x:Class="DnDInitiativeTracker.Pages.CampaignDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Campaign Details"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="{DynamicResource ApplicationBackgroundBrush}">

    <Page.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,3"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24" MaxWidth="560" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="{Binding CampaignName}"
                       FontSize="28" FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding CampaignDescription}"
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,20"/>

            <!-- Section title -->
            <TextBlock Text="Characters"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Add player characters to this campaign. You can import them into encounters later."
                       FontSize="12"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       Margin="0,0,0,16"/>

            <!-- Add character button -->
            <ui:Button Content="Add Character"
                       Icon="{ui:SymbolIcon PersonAdd24}"
                       Command="{Binding BeginAddCharacterCommand}"
                       Appearance="Primary"
                       Margin="0,0,0,16"/>

            <!-- Add character form -->
            <ui:Card Margin="0,0,0,16"
                     Visibility="{Binding IsAddingCharacter, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="NEW CHARACTER" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="CHARACTER NAME" Style="{StaticResource FieldLabel}"/>
                            <ui:TextBox Text="{Binding NewCharacterName, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="e.g. Gandalf"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="DEX MOD" Style="{StaticResource FieldLabel}"/>
                            <ui:TextBox Text="{Binding NewCharacterDexMod, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="0"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               FontSize="11" Margin="0,0,0,8"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullOrEmptyToVisibility}}"/>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Add"
                                   Appearance="Primary"
                                   Command="{Binding ConfirmAddCharacterCommand}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Cancel"
                                   Command="{Binding CancelAddCharacterCommand}"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!-- Character list -->
            <ItemsControl ItemsSource="{Binding Characters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Card Padding="14,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <ui:SymbolIcon Grid.Column="0"
                                               Symbol="Person24"
                                               FontSize="20"
                                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>

                                <!-- Name -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontWeight="SemiBold" FontSize="14"
                                           VerticalAlignment="Center"/>

                                <!-- DEX mod -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="DEX "
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <Binding Path="DexterityModifier" StringFormat="{}{0:+#;-#;+0}" Mode="OneWay"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Delete button -->
                                <ui:Button Grid.Column="3"
                                           Icon="{ui:SymbolIcon Delete24}"
                                           Appearance="Danger"
                                           Padding="6"
                                           VerticalAlignment="Center"
                                           Command="{Binding DataContext.DeleteCharacterCommand,
                                                     RelativeSource={RelativeSource AncestorType=Page}}"
                                           CommandParameter="{Binding}"/>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>

