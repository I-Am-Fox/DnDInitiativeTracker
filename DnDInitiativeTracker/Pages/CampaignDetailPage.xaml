<Page x:Class="DnDInitiativeTracker.Pages.CampaignDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Campaign Details"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32" MaxWidth="600" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="{Binding CampaignName}"
                       Style="{StaticResource PageHeaderStyle}"/>
            <TextBlock Text="{Binding CampaignDescription}"
                       Style="{StaticResource PageSubheaderStyle}"/>

            <!-- Characters section card -->
            <Border Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="CHARACTERS" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock Text="Add player characters to this campaign. You can import them into encounters later."
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Add character button -->
                    <ui:Button Content="Add Character"
                               Icon="{ui:SymbolIcon PersonAdd24}"
                               Command="{Binding BeginAddCharacterCommand}"
                               Appearance="Primary"
                               Style="{StaticResource PrimaryButtonStyle}"
                               Margin="0,0,0,16"/>

                    <!-- Add character form -->
                    <Border CornerRadius="8"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            Padding="16" Margin="0,0,0,16"
                            Visibility="{Binding IsAddingCharacter, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="NEW CHARACTER" Style="{StaticResource SectionHeaderStyle}"/>

                            <TextBlock Text="CHARACTER NAME" Style="{StaticResource FieldLabelStyle}"/>
                            <ui:TextBox Text="{Binding NewCharacterName, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="e.g. Gandalf"
                                        Margin="0,0,0,12"/>

                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                       FontSize="11" Margin="0,0,0,8"
                                       Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullOrEmptyToVisibility}}"/>

                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="Add"
                                           Appearance="Primary"
                                           Style="{StaticResource PrimaryButtonStyle}"
                                           Command="{Binding ConfirmAddCharacterCommand}"
                                           Margin="0,0,8,0"/>
                                <ui:Button Content="Cancel"
                                           Style="{StaticResource SecondaryButtonStyle}"
                                           Command="{Binding CancelAddCharacterCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Character list -->
                    <ItemsControl ItemsSource="{Binding Characters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        Padding="14,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8"
                                                Margin="0,0,12,0" VerticalAlignment="Center"
                                                Background="#2A3A5C">
                                            <ui:SymbolIcon Symbol="Person24" FontSize="16"
                                                           Foreground="#4A90D9"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   VerticalAlignment="Center"/>

                                        <ui:Button Grid.Column="2"
                                                   Icon="{ui:SymbolIcon Delete24}"
                                                   Appearance="Danger"
                                                   Padding="6"
                                                   CornerRadius="8"
                                                   VerticalAlignment="Center"
                                                   Command="{Binding DataContext.DeleteCharacterCommand,
                                                             RelativeSource={RelativeSource AncestorType=Page}}"
                                                   CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

