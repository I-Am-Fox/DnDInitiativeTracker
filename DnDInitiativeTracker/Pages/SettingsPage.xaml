<Page x:Class="DnDInitiativeTracker.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32" MaxWidth="600" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Settings"
                       FontSize="28" FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Configure application preferences."
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,28"/>

            <!-- Appearance Card -->
            <Border Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="APPEARANCE" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon Grid.Column="0" Symbol="DarkTheme24" FontSize="20"
                                       VerticalAlignment="Center" Margin="0,0,12,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Dark Mode" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Toggle between light and dark themes"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <ToggleButton Grid.Column="2"
                                      IsChecked="{Binding IsDarkMode}"
                                      VerticalAlignment="Center"
                                      Width="44" Height="24">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="ToggleBorder"
                                            Width="44" Height="24"
                                            CornerRadius="12"
                                            Background="#555555"
                                            Cursor="Hand">
                                        <Ellipse x:Name="Thumb"
                                                 Width="18" Height="18"
                                                 Fill="White"
                                                 HorizontalAlignment="Left"
                                                 Margin="3,0,0,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="ToggleBorder" Property="Background" Value="#4A90D9"/>
                                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Updates Card -->
            <Border Style="{StaticResource DashboardCardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="UPDATES" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon Grid.Column="0" Symbol="ArrowSync24" FontSize="20"
                                       VerticalAlignment="Center" Margin="0,0,12,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Software Updates" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="Current version:"/>
                                <Run Text="{Binding AppVersion, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Update status -->
                    <TextBlock Text="{Binding Update.StatusText}"
                               FontSize="12" Margin="0,0,0,8"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Visibility="{Binding Update.IsVisible, Converter={StaticResource BoolToVisibility}}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ui:Button Content="Check for Updates"
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Appearance="Primary"
                                   Command="{Binding CheckForUpdatesCommand}"
                                   Style="{StaticResource PrimaryButtonStyle}"
                                   Margin="0,0,8,0"/>

                        <ui:Button Content="Restart &amp; Update"
                                   Icon="{ui:SymbolIcon ArrowReset24}"
                                   Appearance="Primary"
                                   Command="{Binding Update.ApplyUpdateCommand}"
                                   Style="{StaticResource PrimaryButtonStyle}"
                                   Visibility="{Binding Update.CanApply, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- About Card -->
            <Border Style="{StaticResource DashboardCardStyle}">
                <StackPanel>
                    <TextBlock Text="ABOUT" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <TextBlock FontSize="13" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        D&amp;D Initiative Tracker — a streamlined tool for managing
                        combat initiative order in your Dungeons &amp; Dragons campaigns.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

