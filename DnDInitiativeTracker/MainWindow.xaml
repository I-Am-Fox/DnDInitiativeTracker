<ui:FluentWindow x:Class="DnDInitiativeTracker.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:pages="clr-namespace:DnDInitiativeTracker.Pages"
                 Title="D&amp;D Initiative Tracker"
                 Height="740" Width="1100"
                 MinWidth="900" MinHeight="580"
                 WindowStartupLocation="CenterScreen"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Title="D&amp;D Initiative Tracker"
                     Grid.Row="0"/>

        <ui:NavigationView Grid.Row="1"
                           x:Name="RootNavigationView"
                           IsPaneOpen="False"
                           PaneDisplayMode="LeftMinimal">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Campaigns"
                                       TargetPageType="{x:Type pages:CampaignsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="BookStar24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Campaign Details"
                                       TargetPageType="{x:Type pages:CampaignDetailPage}"
                                       Visibility="Collapsed">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="People24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Encounters"
                                       TargetPageType="{x:Type pages:EncountersPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Server24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem Content="Initiative"
                                       TargetPageType="{x:Type pages:InitiativePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="PeopleCommunity24"/>
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>

        <ui:SnackbarPresenter Grid.Row="1"
                              x:Name="SnackbarPresenter"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Bottom"
                              Margin="16"
                              MaxWidth="420"/>

        <!-- Update bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8"
                Visibility="{Binding Update.IsVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Update.StatusText}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>

                <ui:Button Grid.Column="1"
                           Content="Restart &amp; Update"
                           Appearance="Primary"
                           Padding="10,4"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Command="{Binding Update.ApplyUpdateCommand}"
                           Visibility="{Binding Update.CanApply, Converter={StaticResource BoolToVisibility}}"/>

                <ui:Button Grid.Column="2"
                           Content="Check for Updates"
                           Padding="10,4"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Command="{Binding Update.CheckForUpdatesCommand}"
                           Visibility="{Binding Update.UpdateReady, Converter={StaticResource InverseBoolToVisibility}}"/>

                <ui:Button Grid.Column="3"
                           Icon="{ui:SymbolIcon Dismiss24}"
                           Padding="4"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Command="{Binding Update.DismissCommand}"/>
            </Grid>
        </Border>
    </Grid>

</ui:FluentWindow>

