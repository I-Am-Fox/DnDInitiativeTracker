<ui:FluentWindow x:Class="DnDInitiativeTracker.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:pages="clr-namespace:DnDInitiativeTracker.Pages"
                 Title="D&amp;D Initiative Tracker"
                 Height="900" Width="1400"
                 MinWidth="1050" MinHeight="700"
                 WindowStartupLocation="CenterScreen"
                 WindowCornerPreference="Round"
                 Icon="Assets/dice.ico"
                 ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Title="D&amp;D Initiative Tracker"
                     Grid.Row="0"/>

        <!-- Main layout: Sidebar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- LEFT SIDEBAR                                    -->
            <!-- ═══════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource SidebarBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- App branding -->
                    <StackPanel Grid.Row="0" Margin="20,20,20,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8"
                                    Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4A90D9" Offset="0"/>
                                        <GradientStop Color="#357ABD" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="Diversity24" FontSize="18"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="D&amp;D Tracker"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="Initiative Manager"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Navigation items -->
                    <StackPanel Grid.Row="1" Margin="12,0,12,0">
                        <TextBlock Text="N A V I G A T I O N"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Margin="10,0,0,8"/>

                        <ListBox x:Name="NavListBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectionChanged="NavListBox_SelectionChanged"
                                 SelectedIndex="{Binding Shell.SelectedNavIndex, Mode=TwoWay}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemBorder"
                                                        CornerRadius="8"
                                                        Padding="12,10"
                                                        Margin="0,2"
                                                        Background="Transparent"
                                                        Cursor="Hand">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background"
                                                                Value="{DynamicResource NavItemHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background"
                                                                Value="{DynamicResource NavItemSelectedBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <!-- Campaigns -->
                            <ListBoxItem Tag="Campaigns">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="BookStar24" FontSize="16"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Campaigns" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- Campaign Details -->
                            <ListBoxItem Tag="CampaignDetails">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="People24" FontSize="16"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Campaign Details" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- Encounters -->
                            <ListBoxItem Tag="Encounters">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Server24" FontSize="16"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Encounters" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- Initiative -->
                            <ListBoxItem Tag="Initiative">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="PeopleCommunity24" FontSize="16"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Initiative" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </ListBoxItem>

                            <!-- Settings -->
                            <ListBoxItem Tag="Settings">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Settings24" FontSize="16"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Settings" FontSize="13" FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                </StackPanel>
                            </ListBoxItem>
                        </ListBox>
                    </StackPanel>

                    <!-- Footer -->
                    <Border Grid.Row="2" Margin="16,0,16,16" Padding="12,10"
                            CornerRadius="8"
                            Background="{DynamicResource NavItemHoverBrush}">
                        <StackPanel>
                            <TextBlock Text="D&amp;D Initiative Tracker"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="v1.2.0 — Ready"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- MAIN CONTENT AREA                               -->
            <!-- ═══════════════════════════════════════════════ -->
            <Grid Grid.Column="1">
                <!-- Page content -->
                <Frame Content="{Binding Shell.CurrentPage}"
                       NavigationUIVisibility="Hidden"
                       JournalOwnership="OwnsJournal"/>

                <!-- Snackbar overlay -->
                <ui:SnackbarPresenter x:Name="SnackbarPresenter"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Bottom"
                                      Margin="16"
                                      MaxWidth="420"/>
            </Grid>
        </Grid>
    </Grid>

</ui:FluentWindow>

